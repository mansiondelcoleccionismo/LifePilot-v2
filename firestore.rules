rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pasos desde iPhone Shortcut via REST API — sin autenticación
    match /pasos/{fecha} {
      allow read, write: if true;
    }

    // App personal — sin Firebase Auth, todo permitido
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
